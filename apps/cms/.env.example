HOST=0.0.0.0
PORT=1337

# Strapi secrets — kök .env ile aynı değerleri kullanın
APP_KEYS=changeMeKey1,changeMeKey2
API_TOKEN_SALT=changeMeApiTokenSalt
ADMIN_JWT_SECRET=changeMeAdminJwtSecret
TRANSFER_TOKEN_SALT=changeMeTransferTokenSalt
JWT_SECRET=changeMeJwtSecret
ENCRYPTION_KEY=changeMeEncryptionKey32chars!!

# PostgreSQL — yerel geliştirme için localhost
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=blog
DATABASE_USERNAME=blog
DATABASE_PASSWORD=blog_secret
DATABASE_SSL=false
