# PostgreSQL — docker-compose ve Drizzle (@repo/db) bu değerleri kullanır.
# Yerel geliştirmede POSTGRES_HOST=localhost, Docker'da compose otomatik olarak db atar.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL=false
POSTGRES_DB=blog
POSTGRES_USER=blog
POSTGRES_PASSWORD=blog_secret

# Uygulama portları (docker-compose, isteğe bağlı)
WEB_PORT=3000
CMS_PORT=1337

# Strapi adresi
# - NEXT_PUBLIC_STRAPI_URL: tarayıcıya açık adres (medya/link URL'leri). Üretimde
#   DERLEME ANINDA web imajına gömülür; herkese açık alan adı olmalı.
#   Yerelde: http://localhost:1337 — Üretimde: https://cms.alanadiniz.com
# - STRAPI_INTERNAL_URL (yalnızca Docker): web container'ı server-side fetch'i
#   bu adresten yapar. Compose bunu http://cms:1337 olarak set eder; .env'de gerekmez.
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=

# Next.js on-demand revalidation
# Strapi webhook'u, içerik yayınlandığında /api/revalidate adresini bu secret ile
# çağırır; yeni yazı 60 sn beklemeden anında frontend'e düşer.
# Üretmek için: openssl rand -hex 24
REVALIDATE_SECRET=changeMeRevalidateSecret

# Strapi gizli anahtarları — hem Docker hem yerel cms için gerekli
APP_KEYS=changeMeKey1,changeMeKey2
API_TOKEN_SALT=changeMeApiTokenSalt
ADMIN_JWT_SECRET=changeMeAdminJwtSecret
TRANSFER_TOKEN_SALT=changeMeTransferTokenSalt
JWT_SECRET=changeMeJwtSecret
ENCRYPTION_KEY=changeMeEncryptionKey32chars!!
